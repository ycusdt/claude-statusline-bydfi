#!/usr/bin/env python3
"""
Claude Code Statusline - API Stats
Displays API usage statistics in Claude Code's statusline.
"""

import cloudscraper
import json
import os
import re
import subprocess
import sys

# ============================================
# CONFIGURATION - Edit this with your API ID
# ============================================
API_ID = "YOUR_API_ID_HERE"  # <-- Replace with your API ID
# ============================================

# ANSI colors
GREEN = '\033[92m'
YELLOW = '\033[93m'
RED = '\033[91m'
RESET = '\033[0m'

def parse_context_window(display_name):
    """Parse context window size from model display name like 'Opus 4.6 (1M context)'"""
    import re
    match = re.search(r'\((\d+)M\s*context\)', display_name, re.IGNORECASE)
    if match:
        return int(match.group(1)) * 1000000  # Convert M to actual number
    match = re.search(r'\((\d+)K\s*context\)', display_name, re.IGNORECASE)
    if match:
        return int(match.group(1)) * 1000  # Convert K to actual number
    return 200000  # Default 200K

def get_current_context_usage(transcript_path=None, context_window=200000):
    """Get the current context usage from the transcript file

    Args:
        transcript_path: Path to the current session's transcript file (from stdin)
        context_window: Context window size for the current model
    """
    try:
        # If transcript_path is provided, use it directly
        if transcript_path and os.path.exists(transcript_path):
            target_file = transcript_path
        else:
            # Fallback: Find the latest transcript file
            claude_dir = os.path.expanduser("~/.claude/projects")
            if not os.path.exists(claude_dir):
                return None, None

            # Find all jsonl files
            jsonl_files = []
            for root, dirs, files in os.walk(claude_dir):
                for f in files:
                    if f.endswith('.jsonl'):
                        filepath = os.path.join(root, f)
                        mtime = os.path.getmtime(filepath)
                        jsonl_files.append((mtime, filepath))

            if not jsonl_files:
                return None, None

            # Get the most recent file
            jsonl_files.sort(reverse=True)
            target_file = jsonl_files[0][1]

        # Read the file and find the last assistant message with usage
        with open(target_file, 'r') as f:
            lines = f.readlines()

        # Search from the end for the last assistant message with usage
        for line in reversed(lines):
            try:
                data = json.loads(line.strip())
                if data.get('type') == 'assistant' and 'message' in data:
                    usage = data.get('message', {}).get('usage', {})
                    if usage.get('input_tokens') is not None:
                        # Full calculation: input + cache_create + cache_read
                        input_tokens = usage.get('input_tokens', 0)
                        cache_create = usage.get('cache_creation_input_tokens', 0)
                        cache_read = usage.get('cache_read_input_tokens', 0)
                        current_context = input_tokens + cache_create + cache_read

                        percentage = round(current_context / context_window * 100)
                        return current_context, percentage
            except:
                continue

        return None, None
    except Exception:
        return None, None

def make_progress_bar(percentage):
    """Create a colored progress bar"""
    bar_length = 8
    filled = min(int(percentage / 100 * bar_length), bar_length)
    empty = bar_length - filled

    # Choose color based on percentage
    if percentage <= 50:
        color = GREEN
    elif percentage <= 80:
        color = YELLOW
    else:
        color = RED

    bar = color + '█' * filled + '░' * empty + RESET
    return f"{bar}{int(percentage)}%"

# Read stdin (Claude Code passes session info)
stdin_data = sys.stdin.read()

# Parse stdin to get transcript_path and model info for current session
transcript_path = None
model_name = "Claude"
context_window = 200000  # Default 200K
try:
    stdin_json = json.loads(stdin_data)
    transcript_path = stdin_json.get('transcript_path')
    model_info = stdin_json.get('model', {})
    model_name = model_info.get('display_name', 'Claude')
    context_window = parse_context_window(model_name)
except:
    pass

# Get API stats
scraper = cloudscraper.create_scraper()
try:
    resp = scraper.post(
        'https://www.claudecodeserver.top/apiStats/api/user-stats',
        json={"apiId": API_ID},
        timeout=10
    )

    if resp.status_code == 200:
        data = resp.json()
        if data.get('success'):
            limits = data['data']['limits']
            usage = data['data']['usage']['total']

            today_cost = round(limits['currentDailyCost'], 2)
            used_cost = round(limits['currentTotalCost'], 2)
            left_cost = round(limits['totalCostLimit'] - limits['currentTotalCost'], 2)
            in_tokens = round(usage['inputTokens'] / 1000000, 1)
            out_tokens = round(usage['outputTokens'] / 1000)

            api_part = f"💰 ${today_cost} today : ${left_cost} left | 📥 {in_tokens}M in : {out_tokens}K out"
        else:
            api_part = "💰 API Error"
    else:
        api_part = "💰 API Error"
except Exception:
    api_part = "💰 API N/A"

# Get current context usage
current_context, percentage = get_current_context_usage(transcript_path, context_window)

if current_context is not None and percentage is not None:
    # Format context: use K for thousands
    if current_context >= 1000:
        context_display = f"{current_context // 1000}k"
    else:
        context_display = str(current_context)
    brain_part = f"🧠 {context_display} {make_progress_bar(percentage)}"
else:
    brain_part = ""

# Build final output
if brain_part:
    print(f"🤖 {model_name} | {brain_part} | {api_part}")
else:
    print(f"🤖 {model_name} | {api_part}")
