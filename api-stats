#!/usr/bin/env python3
"""
Claude Code Statusline - API Stats
Displays API usage statistics in Claude Code's statusline.
"""

import cloudscraper
import json
import os
import re
import subprocess
import sys

# ============================================
# CONFIGURATION - Edit this with your API ID
# ============================================
API_ID = "YOUR_API_ID_HERE"  # <-- Replace with your API ID
# ============================================

# ANSI colors
GREEN = '\033[92m'
YELLOW = '\033[93m'
RED = '\033[91m'
RESET = '\033[0m'

# Claude context window size
CONTEXT_WINDOW = 200000  # 200K for Opus 4

def get_current_context_usage():
    """Get the current context usage from the latest transcript file"""
    try:
        # Find the latest transcript file
        claude_dir = os.path.expanduser("~/.claude/projects")
        if not os.path.exists(claude_dir):
            return None, None

        # Find all jsonl files
        jsonl_files = []
        for root, dirs, files in os.walk(claude_dir):
            for f in files:
                if f.endswith('.jsonl'):
                    filepath = os.path.join(root, f)
                    mtime = os.path.getmtime(filepath)
                    jsonl_files.append((mtime, filepath))

        if not jsonl_files:
            return None, None

        # Get the most recent file
        jsonl_files.sort(reverse=True)
        latest_file = jsonl_files[0][1]

        # Read the file and find the last assistant message with usage
        with open(latest_file, 'r') as f:
            lines = f.readlines()

        # Search from the end for the last assistant message with usage
        for line in reversed(lines):
            try:
                data = json.loads(line.strip())
                if data.get('type') == 'assistant' and 'message' in data:
                    usage = data.get('message', {}).get('usage', {})
                    if usage.get('input_tokens') is not None:
                        # Correct calculation: input + cache_create (NOT cache_read)
                        input_tokens = usage.get('input_tokens', 0)
                        cache_create = usage.get('cache_creation_input_tokens', 0)
                        current_context = input_tokens + cache_create

                        percentage = round(current_context / CONTEXT_WINDOW * 100)
                        return current_context, percentage
            except:
                continue

        return None, None
    except Exception as e:
        print(f"Debug: {e}", file=sys.stderr)
        return None, None

def make_progress_bar(percentage):
    """Create a colored progress bar"""
    bar_length = 8
    filled = min(int(percentage / 100 * bar_length), bar_length)
    empty = bar_length - filled

    # Choose color based on percentage
    if percentage <= 50:
        color = GREEN
    elif percentage <= 80:
        color = YELLOW
    else:
        color = RED

    bar = color + '█' * filled + '░' * empty + RESET
    return f"{bar}{int(percentage)}%"

# Read stdin (Claude Code passes session info)
stdin_data = sys.stdin.read()

# Get ccusage context info (for model name)
try:
    ccusage_result = subprocess.run(
        ['/Users/yc/.npm-global/bin/ccusage', 'statusline'],
        input=stdin_data,
        capture_output=True,
        text=True,
        timeout=5
    )
    ccusage_output = ccusage_result.stdout.strip()
except Exception:
    ccusage_output = ""

# Get API stats
scraper = cloudscraper.create_scraper()
try:
    resp = scraper.post(
        'https://www.claudecodeserver.top/apiStats/api/user-stats',
        json={"apiId": API_ID},
        timeout=10
    )

    if resp.status_code == 200:
        data = resp.json()
        if data.get('success'):
            limits = data['data']['limits']
            usage = data['data']['usage']['total']

            today_cost = round(limits['currentDailyCost'], 2)
            used_cost = round(limits['currentTotalCost'], 2)
            left_cost = round(limits['totalCostLimit'] - limits['currentTotalCost'], 2)
            in_tokens = round(usage['inputTokens'] / 1000000, 1)
            out_tokens = round(usage['outputTokens'] / 1000)

            api_part = f"💰 ${today_cost} today / ${used_cost} used / ${left_cost} left | 📥 {in_tokens}M in / 📤 {out_tokens}K out"
        else:
            api_part = "💰 API Error"
    else:
        api_part = "💰 API Error"
except Exception:
    api_part = "💰 API N/A"

# Extract model from ccusage output
if ccusage_output:
    # Extract 🤖 model part
    context_part = ccusage_output.split(' | 🔥')[0].split(' | 💰')[0]

    # Get current context usage
    current_context, percentage = get_current_context_usage()

    if current_context is not None and percentage is not None:
        # Format: 🧠 50,000 ██████░░25%
        brain_part = f"🧠 {current_context:,} {make_progress_bar(percentage)}"
    else:
        brain_part = ""

    if brain_part:
        print(f"{context_part} | {brain_part} | {api_part}")
    else:
        print(f"{context_part} | {api_part}")
else:
    print(f"🤖 Opus 4.6 | {api_part}")
